#!/bin/sh

# Print repo + AUR update counts for Waybar.

if ! command -v checkupdates >/dev/null 2>&1 || ! command -v paru >/dev/null 2>&1; then
  printf '{"text":"󰮯 ?","tooltip":"UPDATES\\nmissing checkupdates or paru","class":"error"}\n'
  exit 0
fi

count_lines() {
  printf '%s\n' "$1" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' '
}

repo_output=$(checkupdates 2>/dev/null)
repo_status=$?

case "$repo_status" in
  0)
    repo_count=$(count_lines "$repo_output")
    ;;
  2)
    repo_count=0
    ;;
  *)
    repo_count=-1
    ;;
esac

aur_err=$(mktemp)
aur_output=$(paru -Qua 2>"$aur_err")
aur_status=$?
aur_error_output=$(cat "$aur_err")
rm -f "$aur_err"
aur_unknown=0

if [ "$aur_status" -eq 0 ]; then
  aur_count=$(count_lines "$aur_output")
elif [ "$aur_status" -eq 1 ] && [ -z "$aur_error_output" ]; then
  aur_count=0
else
  aur_count=0
  aur_unknown=1
fi

if [ "$repo_count" -lt 0 ]; then
  printf '{"text":"󰮯 ?","tooltip":"UPDATES\\nrefresh failed","class":"error"}\n'
  exit 0
fi

total_count=$((repo_count + aur_count))

if [ "$aur_unknown" -eq 1 ]; then
  class=partial
  if [ "$repo_count" -gt 0 ]; then
    text_count="${repo_count}+"
    total_label="${repo_count}+"
  else
    text_count="?"
    total_label="?"
  fi
  tooltip=$(printf 'UPDATES\\nrepo %s\\naur  ?\\ntotal %s' "$repo_count" "$total_label")
else
  if [ "$total_count" -eq 0 ]; then
    class=none
  elif [ "$repo_count" -gt 0 ] && [ "$aur_count" -gt 0 ]; then
    class=both
  elif [ "$repo_count" -gt 0 ]; then
    class=repo
  else
    class=aur
  fi
  text_count=$total_count
  tooltip=$(printf 'UPDATES\\nrepo %s\\naur  %s\\ntotal %s' "$repo_count" "$aur_count" "$total_count")
fi

printf '{"text":"󰚰 %s","tooltip":"%s","class":"%s"}\n' "$text_count" "$tooltip" "$class"
